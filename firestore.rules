rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────
    // Funções auxiliares
    // ────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && request.auth.uid == 'Glhzl4mWRkNjttVBLaLhoUWLWxf1';
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isParticipant(chatData) {
      return isAuth() && request.auth.uid in chatData.participants;
    }

    function notChanging(field) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == resource.data[field];
    }

    // ────────────────────────────────────────
    // /users/{userId}
    // ────────────────────────────────────────
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    // ────────────────────────────────────────
    // /providers/{providerId}
    // ────────────────────────────────────────
    match /providers/{providerId} {
      allow read: if true;
      allow create: if isOwner(providerId) || isAdmin();
      allow update: if isOwner(providerId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ────────────────────────────────────────
    // /categories/{catId}
    // ────────────────────────────────────────
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ────────────────────────────────────────
    // /requests/{requestId}  ← nome antigo usado no console
    // /serviceRequests/{requestId}  ← nome usado no código
    // Ambos mapeados com as mesmas regras
    // ────────────────────────────────────────
    match /requests/{requestId} {
      allow read: if isAdmin() ||
        (isAuth() && (
          resource.data.clientId == request.auth.uid ||
          resource.data.providerId == request.auth.uid
        ));
      allow create: if isAuth() && request.resource.data.clientId == request.auth.uid;
      allow update: if isAdmin() ||
        (isAuth() && (
          resource.data.clientId == request.auth.uid ||
          resource.data.providerId == request.auth.uid
        ));
      allow delete: if isAdmin();
    }

    match /serviceRequests/{requestId} {
      allow read: if isAdmin() ||
        (isAuth() && (
          resource.data.clientId == request.auth.uid ||
          resource.data.providerId == request.auth.uid
        ));
      allow create: if isAuth() && request.resource.data.clientId == request.auth.uid;
      allow update: if isAdmin() ||
        (isAuth() && (
          resource.data.clientId == request.auth.uid ||
          resource.data.providerId == request.auth.uid
        ));
      allow delete: if isAdmin();
    }

    // ────────────────────────────────────────
    // /notifications/{notificationId}
    // ────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isAdmin() ||
        (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth();
      allow update, delete: if isAdmin() ||
        (isAuth() && resource.data.userId == request.auth.uid);
    }

    // ────────────────────────────────────────
    // /reviews/{reviewId}
    // ────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.clientId == request.auth.uid;
      allow update, delete: if isAdmin() ||
        (isAuth() && resource.data.clientId == request.auth.uid);
    }

    // ────────────────────────────────────────
    // /cities/{cityId}
    // ────────────────────────────────────────
    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ────────────────────────────────────────
    // /chats/{chatId}
    // ────────────────────────────────────────
    match /chats/{chatId} {
      // Admin vê tudo; participantes vêem apenas seu chat
      allow read: if isAdmin() || isParticipant(resource.data);

      // Criar: usuário autenticado deve estar na lista de participants (exatamente 2)
      allow create: if isAuth() &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() == 2;

      // Atualizar: participante pode atualizar (ex: unreadCount, lastMessage)
      // A lista de participants é imutável após a criação
      allow update: if isAdmin() ||
        (isParticipant(resource.data) && notChanging('participants'));

      allow delete: if isAdmin();

      // ── /chats/{chatId}/messages/{messageId} ──
      match /messages/{messageId} {
        // Apenas participantes do chat pai lêem mensagens
        allow read: if isAdmin() ||
          (isAuth() && request.auth.uid in
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants);

        // Enviar mensagem: participante + senderId = auth.uid + texto válido (1–2000 chars)
        allow create: if isAuth() &&
          request.auth.uid in
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() >= 1 &&
          request.resource.data.text.size() <= 2000;

        // Mensagens são imutáveis (sem edição ou deleção por clientes)
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    // ────────────────────────────────────────
    // Qualquer outra coleção — apenas admin acessa
    // (substitui o wildcard permissivo anterior)
    // ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
