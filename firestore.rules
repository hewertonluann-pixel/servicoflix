rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────
    // Funções auxiliares
    // ─────────────────────────────────────────

    // Verifica se o usuário está autenticado
    function isAuth() {
      return request.auth != null;
    }

    // Verifica se o usuário autenticado é o dono do recurso
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Verifica se o usuário autenticado é participante do chat
    function isParticipant(chatData) {
      return isAuth() && request.auth.uid in chatData.participants;
    }

    // Verifica se o campo não está sendo alterado
    function notChanging(field) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == resource.data[field];
    }

    // ─────────────────────────────────────────
    // /users/{userId}
    // ─────────────────────────────────────────
    match /users/{userId} {
      // Qualquer um pode ler perfis públicos (necessário para buscar nome/avatar no chat)
      allow read: if true;

      // Apenas o próprio usuário pode criar/atualizar seu perfil
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // nunca deletar via client
    }

    // ─────────────────────────────────────────
    // /providers/{providerId}
    // ─────────────────────────────────────────
    match /providers/{providerId} {
      // Listagem pública de prestadores (busca, perfil)
      allow read: if true;

      // Apenas o próprio prestador pode criar/editar
      allow create: if isOwner(providerId);
      allow update: if isOwner(providerId);
      allow delete: if false;
    }

    // ─────────────────────────────────────────
    // /serviceRequests/{requestId}
    // ─────────────────────────────────────────
    match /serviceRequests/{requestId} {
      // Prestador lê suas solicitações | Cliente lê as próprias
      allow read: if isAuth() &&
        (request.auth.uid == resource.data.providerId ||
         request.auth.uid == resource.data.clientId);

      // Cliente autenticado pode criar uma solicitação
      allow create: if isAuth() &&
        request.resource.data.clientId == request.auth.uid;

      // Prestador pode atualizar status | Cliente pode cancelar
      allow update: if isAuth() &&
        (request.auth.uid == resource.data.providerId ||
         request.auth.uid == resource.data.clientId);

      allow delete: if false;
    }

    // ─────────────────────────────────────────
    // /chats/{chatId}
    // ─────────────────────────────────────────
    match /chats/{chatId} {
      // Apenas participantes podem ler o chat
      allow read: if isParticipant(resource.data);

      // Criação: usuário autenticado que está na lista de participants
      allow create: if isAuth() &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() == 2;

      // Atualização: apenas participantes podem atualizar
      // E não podem alterar a lista de participants nem o chatId
      allow update: if isParticipant(resource.data) &&
        notChanging('participants');

      allow delete: if false;

      // ── /chats/{chatId}/messages/{messageId} ──
      match /messages/{messageId} {
        // Apenas participantes do chat pai podem ler mensagens
        allow read: if isAuth() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // Apenas participantes podem enviar mensagens
        // E o senderId deve ser o próprio usuário autenticado
        allow create: if isAuth() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 2000;

        // Mensagens não podem ser editadas nem deletadas
        allow update: if false;
        allow delete: if false;
      }
    }

    // ─────────────────────────────────────────
    // /cities/{cityId} — somente leitura pública
    // ─────────────────────────────────────────
    match /cities/{cityId} {
      allow read: if true;
      allow write: if false;
    }

    // ─────────────────────────────────────────
    // Qualquer outra coleção — bloqueado por padrão
    // ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
