rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────
    // Funções auxiliares
    // ────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && request.auth.uid == 'Glhzl4mWRkNjttVBLaLhoUWLWxf1';
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ✅ Corrigido: participants é array — usar hasAny() em vez de `in`
    function isParticipant(chatData) {
      return isAuth() && chatData.participants.hasAny([request.auth.uid]);
    }

    function notChanging(field) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == resource.data[field];
    }

    // ────────────────────────────────────────
    // /users/{userId}
    // ────────────────────────────────────────
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    // ────────────────────────────────────────
    // /providers/{providerId}
    // ────────────────────────────────────────
    match /providers/{providerId} {
      allow read: if true;
      allow create: if isOwner(providerId) || isAdmin();
      allow update: if isOwner(providerId) || isAdmin();
      allow delete: if isAdmin();

      match /portfolio/{mediaId}/comments/{commentId} {
        allow read: if true;

        allow create: if isAuth() &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() >= 1 &&
          request.resource.data.text.size() <= 500;

        allow update: if isAuth() && (
          (resource.data.userId == request.auth.uid) ||
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['likes', 'likedBy'])
          )
        );

        allow delete: if isAdmin() ||
          resource.data.userId == request.auth.uid ||
          isOwner(providerId);
      }
    }

    // ────────────────────────────────────────
    // /categories/{catId}
    // ────────────────────────────────────────
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ────────────────────────────────────────
    // /requests/{requestId}
    // /serviceRequests/{requestId}
    // ────────────────────────────────────────
    match /requests/{requestId} {
      allow read: if isAdmin() ||
        (isAuth() && (
          resource.data.clientId == request.auth.uid ||
          resource.data.providerId == request.auth.uid
        ));
      allow create: if isAuth() && request.resource.data.clientId == request.auth.uid;
      allow update: if isAdmin() ||
        (isAuth() && (
          resource.data.clientId == request.auth.uid ||
          resource.data.providerId == request.auth.uid
        ));
      allow delete: if isAdmin();
    }

    match /serviceRequests/{requestId} {
      allow read: if isAdmin() ||
        (isAuth() && (
          resource.data.clientId == request.auth.uid ||
          resource.data.providerId == request.auth.uid
        ));
      allow create: if isAuth() && request.resource.data.clientId == request.auth.uid;
      allow update: if isAdmin() ||
        (isAuth() && (
          resource.data.clientId == request.auth.uid ||
          resource.data.providerId == request.auth.uid
        ));
      allow delete: if isAdmin();
    }

    // ────────────────────────────────────────
    // /notifications/{notificationId}
    // ────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isAdmin() ||
        (isAuth() && resource.data.userId == request.auth.uid);
      allow create: if isAuth();
      allow update, delete: if isAdmin() ||
        (isAuth() && resource.data.userId == request.auth.uid);
    }

    // ────────────────────────────────────────
    // /reviews/{reviewId}
    // ────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.clientId == request.auth.uid;
      allow update, delete: if isAdmin() ||
        (isAuth() && resource.data.clientId == request.auth.uid);
    }

    // ────────────────────────────────────────
    // /cities/{cityId}
    // ────────────────────────────────────────
    match /cities/{cityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ────────────────────────────────────────
    // /chats/{chatId}
    // ────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAdmin() || isParticipant(resource.data);

      allow create: if isAuth() &&
        request.resource.data.participants.hasAny([request.auth.uid]) &&
        request.resource.data.participants.size() == 2;

      allow update: if isAdmin() ||
        (isParticipant(resource.data) && notChanging('participants'));

      allow delete: if isAdmin() || isParticipant(resource.data);

      // ── /chats/{chatId}/messages/{messageId} ──
      match /messages/{messageId} {
        // ✅ Corrigido: hasAny() para verificar array de participants
        allow read: if isAdmin() ||
          (isAuth() &&
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants
              .hasAny([request.auth.uid]));

        allow create: if isAuth() &&
          get(/databases/$(database)/documents/chats/$(chatId)).data.participants
            .hasAny([request.auth.uid]) &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() >= 1 &&
          request.resource.data.text.size() <= 2000;

        allow update: if isAdmin();

        allow delete: if isAdmin() ||
          (isAuth() &&
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants
              .hasAny([request.auth.uid]));
      }
    }

    // ────────────────────────────────────────
    // Qualquer outra coleção — apenas admin
    // ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
