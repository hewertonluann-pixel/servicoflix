rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Função auxiliar: verifica se é admin ──
    function isAdmin() {
      return request.auth != null
        && request.auth.uid == 'Glhzl4mWRkNjttVBLaLhoUWLWxf1';
    }

    // ── Avatares de usuários ──
    // Caminho: avatars/{userId}/{fileName}
    match /avatars/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (request.auth.uid == userId || isAdmin())
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Avatares de prestadores ──
    // Caminho: provider-avatars/{userId}/{fileName}
    match /provider-avatars/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (request.auth.uid == userId || isAdmin())
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Fotos de capa de prestadores ──
    // Caminho: covers/{userId}/{fileName}
    match /covers/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (request.auth.uid == userId || isAdmin())
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Mídias do Chat ──
    // Caminho: chats/{chatId}/{fileName}
    match /chats/{chatId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024;
    }

    // ── Portfólio de prestadores (caminho legado) ──
    // Caminho: providers/{userId}/portfolio/{fileName}
    match /providers/{userId}/portfolio/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (request.auth.uid == userId || isAdmin())
                   && request.resource.size < 20 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Galeria de fotos do portfólio ──
    // Caminho: portfolio/{userId}/photos/{fileName}
    match /portfolio/{userId}/photos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (request.auth.uid == userId || isAdmin())
                   && request.resource.size < 20 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Vídeos do portfólio ──
    // Caminho: portfolio/{userId}/videos/{fileName}
    match /portfolio/{userId}/videos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (request.auth.uid == userId || isAdmin())
                   && request.resource.size < 100 * 1024 * 1024
                   && request.resource.contentType.matches('video/.*');
    }

    // ── Áudios do portfólio ──
    // Caminho: portfolio/{userId}/audios/{fileName}
    match /portfolio/{userId}/audios/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (request.auth.uid == userId || isAdmin())
                   && request.resource.size < 20 * 1024 * 1024
                   && request.resource.contentType.matches('audio/.*');
    }

    // ── Bloqueia tudo que não se encaixa nas regras acima ──
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
