rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Função auxiliar: verifica se é admin (mesmo padrão do firestore.rules) ──
    function isAdmin() {
      return request.auth != null
        && request.auth.uid == 'Glhzl4mWRkNjttVBLaLhoUWLWxf1';
    }

    // ── Avatares de usuários ──────────────────────────────────────────────────
    // Caminho: avatars/{userId}/avatar
    match /avatars/{userId}/{fileName} {
      // Qualquer pessoa autenticada pode LER avatares (exibir foto de perfil)
      allow read: if request.auth != null;

      // Próprio usuário OU admin podem fazer upload/deletar
      allow write: if request.auth != null
                   && (request.auth.uid == userId || isAdmin())
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Mídias do Chat ────────────────────────────────────────────────────────
    // Caminho: chats/{chatId}/{fileName}
    match /chats/{chatId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024;
    }

    // ── Portfólio de prestadores ──────────────────────────────────────────────
    // Caminho: providers/{userId}/portfolio/{fileName}
    match /providers/{userId}/portfolio/{fileName} {
      allow read: if request.auth != null;

      // Próprio prestador OU admin podem fazer upload
      allow write: if request.auth != null
                   && (request.auth.uid == userId || isAdmin())
                   && request.resource.size < 20 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Bloqueia tudo que não se encaixa nas regras acima ─────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
